{
    "name": "astro-seo-blog",
    "type": "module",
    "version": "1.0.0",
    "description": "A modern, SEO-optimized blog template built with Astro, featuring dark mode, search, RSS feeds, and multi-language support",
    "author": "Damon Cote <damoncote7@gmail.com>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/DamonCote/astro-seo-blog"
    },
    "keywords": [
        "astro",
        "blog",
        "template",
        "seo",
        "mdx",
        "tailwind",
        "dark-mode",
        "rss"
    ],
    "scripts": {
        "dev": "astro dev",
        "start": "HOST=0.0.0.0 ENV=production PORT=${PORT:-8002} node ./dist/server/entry.mjs",
        "build": "astro build",
        "preview": "astro preview",
        "astro": "astro",
        "update-posts": "node scripts/update-posts.js"
    },
    "dependencies": {
        "@astrojs/markdoc": "^0.15.5",
        "@astrojs/mdx": "^4.3.4",
        "@astrojs/node": "^9.5.4",
        "@astrojs/react": "^4.3.0",
        "@astrojs/rss": "^4.0.15",
        "@astrojs/sitemap": "^3.5.1",
        "@astrojs/tailwind": "^6.0.2",
        "@tailwindcss/typography": "^0.5.16",
        "astro": "^5.18.0",
        "astro-seo": "^0.8.4",
        "clsx": "^2.1.1",
        "direction": "^2.0.1",
        "dotenv": "^17.3.1",
        "gray-matter": "^4.0.3",
        "lodash": "^4.17.21",
        "lodash.debounce": "^4.0.8",
        "marked": "^16.2.1",
        "sass": "^1.97.3",
        "sharp": "^0.34.3",
        "tailwind-merge": "^3.3.1",
        "vite": "^6.3.5",
        "vite-plugin-node-polyfills": "^0.25.0"
    },
    "devDependencies": {
        "vite": "^6.3.5"
    },
    "resolutions": {
        "vite": "^5.2.0"
    }
}
