---
import { SITE_CONFIG } from "@/data/site-config";

export interface Props {
    siteName?: string;
}

const { siteName = SITE_CONFIG.title } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="border-t mt-auto">
    <div class="container py-6">
        <div
            class="flex flex-col lg:flex-row justify-between items-center gap-4"
        >
            <!-- Left: Copyright & Info -->
            <div class="text-center lg:text-left">
                <p class="text-sm text-text-muted">
                    © {currentYear}
                    {SITE_CONFIG.title}. Built by <a
                        href="https://apatero.com"
                        target="_blank"
                        class="hover:text-text transition-colors">Apatero</a
                    >. Open Source • MIT License
                </p>
            </div>

            <!-- Center: Links -->
            <div
                class="flex flex-wrap justify-center gap-3 text-xs text-text-muted order-last lg:order-none"
            >
                <a href="/blog" class="hover:text-text transition-colors"
                    >Blog</a
                >
                <span class="text-text-muted/50">•</span>
                <a href="/about" class="hover:text-text transition-colors"
                    >About</a
                >
            </div>

            <!-- Right: Social Icons -->
            <div class="flex items-center gap-4">
                {
                    SITE_CONFIG.features.rss && (
                        <a
                            href="/rss.xml"
                            class="text-sm text-text-muted hover:text-text transition-colors"
                            aria-label="RSS Feed"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <path d="M4 11a9 9 0 0 1 9 9" />
                                <path d="M4 4a16 16 0 0 1 16 16" />
                                <circle cx="5" cy="19" r="1" />
                            </svg>
                        </a>
                    )
                }
            </div>
        </div>
    </div>
</footer>
