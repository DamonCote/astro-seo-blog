---
import { SITE_CONFIG } from "@/data/site-config";
---

<div class="container py-24 lg:py-32">
    <div class="max-w-5xl mx-auto">
        <!-- Header -->
        <div class="mb-20">
            <h1
                class="text-4xl lg:text-5xl font-display font-bold mb-6 leading-tight"
            >
                ABOUT <span class="text-text-muted">{SITE_CONFIG.title}</span>
            </h1>
            <p class="text-sm lg:text-base text-text-muted max-w-3xl">
                {SITE_CONFIG.description}
            </p>
        </div>

        <!-- Mission Section -->
        <div class="mb-24 pb-16 border-b border-border">
            <h2 class="text-2xl lg:text-3xl font-display font-bold mb-8">
                Our Mission
            </h2>
            <p
                class="text-sm lg:text-base text-text-muted mb-6 leading-relaxed"
            >
                EvoArt.ai is dedicated to exploring the intersection of art and
                technology, pushing the boundaries of creativity through
                artificial intelligence. We believe that AI can be a powerful
                tool for artists, enabling new forms of expression and
                collaboration.
            </p>
            <p
                class="text-sm lg:text-base text-text-muted mb-6 leading-relaxed"
            >
                Our mission is to provide artists and creators with the
                resources, inspiration, and community they need to harness the
                potential of AI in their work. We aim to foster a vibrant
                ecosystem where art and technology can thrive together,
                inspiring innovation and creativity in the digital age.
            </p>
        </div>

        <!-- Open Source -->
    </div>
</div>


  <!-- Schema.org Structured Data -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
       "@type": "WebSite",
       "name": SITE_CONFIG.title,
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Web",
      "description": SITE_CONFIG.description,
      "url": SITE_CONFIG.url,
      "author": {
        "@type": "Person",
        "name": "CoffeeStyle",
        "url": "https://www.coffeestyle.info"
      },
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD",
        "description": "Free and open source under MIT License"
      },
      "featureList": [
        "Coffee Culture Blog",
        "CoffeeStyle",
        "Coffee Reviews",
        "Coffee Brewing Guides",
        "Coffee Bean Origins",
        "Coffee Equipment",
        "Coffee Recipes",
        "Coffee Trends",
        "Coffee Lifestyle"
      ]
    }
  </script>