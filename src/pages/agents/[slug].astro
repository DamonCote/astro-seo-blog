---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
    formatDate,
    calculateReadingTime,
    extractHeadings,
    extractFAQ,
    extractReviews,
    slugify,
} from "../../lib/utils";
import PostCard from "../../components/blog/PostCard.astro";
import BlogSidebar from "../../components/blog/BlogSidebar.astro";
import BackToTop from "../../components/blog/BackToTop.astro";
import TableOfContents from "../../components/blog/TableOfContents.astro";
import ReadingProgress from "../../components/blog/ReadingProgress.astro";
import SocialShare from "../../components/blog/SocialShare.astro";
import { SITE_CONFIG } from "../../data/site-config";
import {
    getAIAgent,
    getPublishedAIAgents,
    getAllAIAgents,
    getAvailableLanguagesForAgent,
} from "../../lib/agents";
import { normalizeTagName } from "../../lib/utils";
import { DEFAULT_LANGUAGE } from "../../config/languages";
import { marked } from "marked";
import fs from "fs/promises";
import path from "path";
import AgentSidebar from "../../components/agent/AgentSidebar.astro";

// Enable prerendering for this page
export const prerender = true;

// Static paths for all AI agents
export async function getStaticPaths() {
    const agents = await getAllAIAgents();
    return agents.map((agent) => ({
        params: { slug: agent.slug },
    }));
}

// Get the slug from the URL
const { slug } = Astro.params;

// Get the specific AI agent
const agent = await getAIAgent(slug);

if (!agent) {
    return new Response(null, {
        status: 404,
        statusText: "Agent not found",
    });
}

// Configure marked to add IDs to headings
marked.use({
    renderer: {
        heading({ tokens, depth }) {
            const text = this.parser.parseInline(tokens);
            const slug = slugify(text);
            return `<h${depth} id="${slug}">${text}</h${depth}>`;
        },
    },
});

// Convert markdown to HTML
const contentHtml = marked(agent.body);

// Split content for multiple mid-article CTAs (Optimized 3-CTA strategy)
const splitContentForCTAs = (html: string) => {
    const paragraphs = html.split(/<\/p>/gi);
    const totalParagraphs = paragraphs.length;

    // CTA #1: Course awareness banner at ~15% (early, lightweight)
    const firstSplitPoint = Math.min(3, Math.floor(totalParagraphs * 0.15));
    // CTA #2: GitHub workflows at ~35% (free value, builds trust)
    const secondSplitPoint = Math.floor(totalParagraphs * 0.35);
    // CTA #3: Apatero alternative at ~50% (for readers who want no-code)
    const thirdSplitPoint = Math.floor(totalParagraphs * 0.5);
    // CTA #4: Main course CTA at ~65% (MAIN conversion - after value delivered)
    const fourthSplitPoint = Math.floor(totalParagraphs * 0.65);

    const beforeFirst =
        paragraphs.slice(0, firstSplitPoint).join("</p>") + "</p>";
    const betweenFirstSecond =
        paragraphs.slice(firstSplitPoint, secondSplitPoint).join("</p>") +
        (firstSplitPoint < secondSplitPoint ? "</p>" : "");
    const betweenSecondThird =
        paragraphs.slice(secondSplitPoint, thirdSplitPoint).join("</p>") +
        (secondSplitPoint < thirdSplitPoint ? "</p>" : "");
    const betweenThirdFourth =
        paragraphs.slice(thirdSplitPoint, fourthSplitPoint).join("</p>") +
        (thirdSplitPoint < fourthSplitPoint ? "</p>" : "");
    const afterFourth = paragraphs.slice(fourthSplitPoint).join("</p>");

    return {
        beforeFirst,
        betweenFirstSecond,
        betweenSecondThird,
        betweenThirdFourth,
        afterFourth,
    };
};

const {
    beforeFirst,
    betweenFirstSecond,
    betweenSecondThird,
    betweenThirdFourth,
    afterFourth,
} = splitContentForCTAs(contentHtml);

// Get author information
let authorInfo = null;
try {
    const authorsPath = path.join(
        process.cwd(),
        "public",
        "data",
        "authors",
        "authors.json",
    );
    const authorsData = JSON.parse(await fs.readFile(authorsPath, "utf-8"));
    authorInfo =
        authorsData.authors.find((a) => a.id === agent.data.author) || null;
} catch (e) {
    console.error("Error loading author:", e);
}

// Get related agents (same category)
const allAgents = await getPublishedAIAgents();
const relatedAgents = allAgents.filter((a) => a.slug !== agent.slug);
const relatedAgentsLimited = relatedAgents.slice(0, 3);
const featuredAgent =
    allAgents.find((a) => a.data.featured && a.slug !== agent.slug) ||
    allAgents.find((a) => a.slug !== agent.slug);

const readingTime = calculateReadingTime(agent.body);

// Extract headings for Table of Contents
const headings = extractHeadings(agent.body);

// Extract FAQ items for schema
const faqItems = extractFAQ(agent.body);

// Extract review items for schema
const reviewItems = extractReviews(agent.body);

// Get available languages for this post (for hreflang tags)
const availableLanguages = await getAvailableLanguagesForAgent(slug);

const articleData = {
    publishedTime: agent.data.publishDate,
    modifiedTime: agent.data.updateDate,
    author: agent.data.author,
};
---

<BaseLayout
    title={agent.data.seoTitle || agent.data.title}
    description={agent.data.seoDescription || agent.data.description}
    ogImage={agent.data.ogImage || agent.data.heroImage}
    article={articleData}
    noindex={agent.data.noindex}
    breadcrumb={[
        { name: "Home", url: "/" },
        { name: "Agents", url: "/agents" },
        { name: agent.data.title, url: `/agents/${agent.slug}` },
    ]}
    siteName={SITE_CONFIG.title}
    currentLanguage={DEFAULT_LANGUAGE}
    availableLanguages={availableLanguages}
    currentSlug={slug}
    faq={faqItems.length > 0 ? faqItems : undefined}
    reviews={reviewItems.length > 0 ? reviewItems : undefined}
    currentNav="AI Agents"
>
    <div class="container py-12">
        <div class="grid lg:grid-cols-[1fr,320px] gap-12">
            <!-- Main Content -->
            <article class="max-w-none">
                <!-- Breadcrumb -->
                <div class="flex items-center gap-3 mb-6">
                    <a
                        href="/blog"
                        class="text-text-muted hover:text-text transition-colors"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"
                            ></path>
                            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"
                            ></path>
                        </svg>
                    </a>
                    <span class="text-text-muted">/</span>

                    <span class="font-medium text-sm truncate max-w-xs"
                        >{agent.data.title}</span
                    >
                </div>

                <!-- Article Header -->
                <header class="mb-8">
                    <div
                        class="flex items-center gap-2 text-sm text-text-muted mb-4"
                    >
                        <time datetime={agent.data.publishDate.toISOString()}>
                            {formatDate(agent.data.publishDate)}
                        </time>
                        <span>•</span>
                        <span>{readingTime} min read</span>
                    </div>

                    <h1
                        class="text-4xl font-display font-bold mb-4 text-balance"
                    >
                        {agent.data.title}
                    </h1>

                    <p class="text-sm text-text-muted"></p>
                </header>

                {/* Hero Image */}
                {
                    agent.data.heroImage && (
                        <div class="mb-8 rounded-lg overflow-hidden">
                            <img
                                src={agent.data.heroImage}
                                alt={
                                    agent.data.heroImageAlt ||
                                    `${agent.data.title}`
                                }
                                class="w-full h-auto"
                            />
                        </div>
                    )
                }

                {/* Article Content - Part 1 (0-15%) */}
                <div class="prose-custom" set:html={beforeFirst} />

                {/* CTA #1 - Course Top Banner (15%) - Lightweight awareness */}

                {/* Article Content - Part 2 (15-35%) */}
                <div class="prose-custom" set:html={betweenFirstSecond} />

                {
                    /* CTA #2 - GitHub Workflows (35%) - Free value, builds trust */
                }

                {/* Article Content - Part 3 (35-50%) */}
                <div class="prose-custom" set:html={betweenSecondThird} />

                {/* CTA #3 - Apatero Alternative (50%) - No-code option */}

                {/* Article Content - Part 4 (50-65%) */}
                <div class="prose-custom" set:html={betweenThirdFourth} />

                {
                    /* Article Content - Part 5 (65-100%) - Conclusion & advanced tips */
                }
                <div class="prose-custom" set:html={afterFourth} />

                {
                    /* CTA #5 - Bottom Urgency CTA (100%) - Final conversion push */
                }

                {/* Social Share Buttons */}
                <SocialShare
                    title={agent.data.title}
                    url={`${SITE_CONFIG.url}/agents/${agent.slug}`}
                    description={agent.data.description}
                />

                {/* Related Agents */}
                {
                    relatedAgentsLimited.length > 0 && (
                        <div class="mt-12 pt-12 border-t">
                            <h3 class="text-2xl font-semibold mb-8 text-center">
                                Related Agents
                            </h3>
                            <div class="grid md:grid-cols-3 gap-6">
                                {relatedAgentsLimited.map((relatedAgent) => (
                                    <a
                                        href={`/agents/${relatedAgent.slug}`}
                                        class="block group"
                                    >
                                        <div class="border border-border rounded-xl overflow-hidden hover:bg-surface transition-colors">
                                            {relatedAgent.data.heroImage && (
                                                <div class="aspect-video overflow-hidden">
                                                    <img
                                                        src={
                                                            relatedAgent.data
                                                                .heroImage
                                                        }
                                                        alt={
                                                            relatedAgent.data
                                                                .heroImageAlt ||
                                                            `${relatedAgent.data.title} - Related ${relatedAgent.data.category} tutorial`
                                                        }
                                                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                                                        loading="lazy"
                                                    />
                                                </div>
                                            )}
                                            <div class="p-4">
                                                <div class="text-xs text-text-muted mb-2">
                                                    {formatDate(
                                                        relatedAgent.data
                                                            .publishDate,
                                                    )}
                                                </div>
                                                <h4 class="text-sm font-semibold mb-2 group-hover:opacity-70 transition-opacity line-clamp-2">
                                                    {relatedAgent.data.title}
                                                </h4>
                                                <p class="text-xs text-text-muted line-clamp-3">
                                                    {
                                                        relatedAgent.data
                                                            .description
                                                    }
                                                </p>
                                            </div>
                                        </div>
                                    </a>
                                ))}
                            </div>
                        </div>
                    )
                }
            </article>

            <!-- Sidebar -->
            <AgentSidebar
                post={agent}
                readingTime={readingTime}
                language={DEFAULT_LANGUAGE}
            />
        </div>
    </div>

    <!-- Article Schema for SEO -->
    <script
        type="application/ld+json"
        set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "BlogPosting",
            headline: agent.data.title,
            description: agent.data.description,
            image: agent.data.heroImage
                ? `${SITE_CONFIG.url}${agent.data.heroImage}`
                : `${SITE_CONFIG.url}/og-image.png`,
            datePublished: agent.data.publishDate.toISOString(),
            dateModified: agent.data.updateDate
                ? agent.data.updateDate.toISOString()
                : agent.data.publishDate.toISOString(),
            author: {
                "@type": authorInfo ? "Person" : "Organization",
                name: authorInfo?.name || "Apatero Team",
                url: authorInfo
                    ? `${SITE_CONFIG.url}/author/${agent.data.author}`
                    : SITE_CONFIG.url,
                ...(authorInfo?.avatar && { image: authorInfo.avatar }),
            },
            publisher: {
                "@type": "Organization",
                name: SITE_CONFIG.title,
                url: SITE_CONFIG.url,
                logo: {
                    "@type": "ImageObject",
                    url: `${SITE_CONFIG.url}/favicon.svg`,
                },
            },
            mainEntityOfPage: {
                "@type": "WebPage",
                "@id": `${SITE_CONFIG.url}/agents/${agent.slug}`,
            },
            articleSection: "AI Agents",
            keywords: agent.data.seoKeywords || "",
            wordCount: agent.body.split(/\s+/).length,
            timeRequired: `PT${readingTime}M`,
            inLanguage: "en-US",
        })}
    />

    <!-- FAQ Schema for common blog post questions -->
    <script
        type="application/ld+json"
        set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "FAQPage",
            mainEntity: [
                {
                    "@type": "Question",
                    name: `What will I learn from this ${agent.data.title.toLowerCase()} tutorial?`,
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: `${agent.data.description} This comprehensive guide covers all the essential concepts and practical steps you need to master ${agent.data.title.toLowerCase()}.`,
                    },
                },
            ],
        })}
    />

    <!-- HowTo Schema for tutorial posts -->
    {
        headings.filter((h) => h.depth === 2).length >= 2 && (
            <script
                type="application/ld+json"
                set:html={JSON.stringify({
                    "@context": "https://schema.org",
                    "@type": "HowTo",
                    name: agent.data.title,
                    description: agent.data.description,
                    image: agent.data.heroImage
                        ? {
                              "@type": "ImageObject",
                              url: `${SITE_CONFIG.url}${agent.data.heroImage}`,
                              width: 1200,
                              height: 630,
                          }
                        : undefined,
                    totalTime: `PT${readingTime}M`,
                    estimatedCost: {
                        "@type": "MonetaryAmount",
                        currency: "USD",
                        value: "0",
                    },
                    supply: [
                        {
                            "@type": "HowToSupply",
                            name: "Computer with internet connection",
                        },
                    ],
                    tool: undefined,
                    step: headings
                        .filter((h) => h.depth === 2)
                        .slice(0, 10)
                        .map((heading, index) => ({
                            "@type": "HowToStep",
                            position: index + 1,
                            name: heading.text,
                            url: `${SITE_CONFIG.url}/agents/${agent.slug}#${heading.slug}`,
                            text: heading.text,
                        })),
                })}
            />
        )
    }

    <!-- Back to Top Button -->
    <BackToTop />

    <!-- Reading Progress Bar -->
    <ReadingProgress />
</BaseLayout>
